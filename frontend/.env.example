# Backend API Server
# Replace __BACKEND_URL__ with actual backend IP before deployment
# Or set VITE_API_URL at build time: VITE_API_URL=http://192.168.1.109:8080 pnpm build
VITE_API_URL=http://192.168.1.109:8080

# Video Processing Defaults (can be overridden per-video)
VITE_DEFAULT_CHUNK_DURATION=30

# Database (Hard coded)
# DATABASE_URL=sqlite+aiosqlite:///data/learning.db

# Storage (Default on PROJECT_ROOT/data)
# STORAGE_BASE_PATH=/data
# LLM_MODEL_PATH=/data/models

# LLM Configuration
DEFAULT_MODEL=Qwen3.5-2B-Q4_K_M.gguf
LLM_GPU_LAYERS=-1
LLM_CONTEXT_SIZE=8192
LLM_THREADS=4

# YouTube Download
YOUTUBE_DOWNLOAD_QUALITY=720
YOUTUBE_AUDIO_QUALITY=128k
CHUNK_DURATION=60

# App Settings
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Backend URL for frontend config (set to this server's URL for cross-origin access)
BACKEND_URL=http://192.168.1.109:8080

# CORS (comma-separated list of allowed origins, or * for all)
CORS_ALLOW_ORIGINS=*
